# BASIC SETTINGS
# ===========================================

# Secret key for Flask sessions (required)
SECRET_KEY=your_secret_key_here

# Time zone (for example: Europe/Moscow, UTC, Europe/London)
TIMEZONE=Europe/Moscow

# Logging level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO

# Image settings
MAX_IMAGE_WIDTH=3840
MAX_IMAGE_HEIGHT=2160
MAX_IMAGE_SIZE_MB=5

# Document upload settings
MAX_DOCUMENT_SIZE_MB=25

# Voice message (recorded) settings
MAX_VOICE_SIZE_MB=5

# Uploaded audio file settings
MAX_AUDIO_SIZE_MB=5

# Ollama settings (required)
#OLLAMA_URL=http://flai-ollama:11434

# Automatic1111 settings (for image generation)
AUTOMATIC1111_URL=http://flai-sd:7860
# Model for Automatic1111 (Stable Diffusion checkpoint)
AUTOMATIC1111_MODEL=RealVisXL_V4.0.safetensors
# Timeout for image generation
AUTOMATIC1111_TIMEOUT=180

# URL for Whisper API (audio transcription)
WHISPER_API_URL=http://flai-whisper:9000/asr

# Audio transcription timeout
WHISPER_API_TIMEOUT=120

# Video surveillance system settings
CAMERA_API_URL=http://room-snapshot-api-api-1:5000
CAMERA_ENABLED=true                # true - module enabled, false - disabled
# Timeout for taking pictures from cameras
CAMERA_API_TIMEOUT=15
# Camera availability check interval (seconds)
CAMERA_CHECK_INTERVAL=30

# Piper TTS settings (text-to-speech)
PIPER_URL=http://flai-piper:8888/tts
PIPER_TIMEOUT=30

# Token estimation: approximate number of characters per token
TOKEN_CHARS=3
# Percentage of model's context window reserved for conversation history (e.g., 75)
CONTEXT_HISTORY_PERCENT=75

# Qdrant settings for RAG (optional)
QDRANT_URL=http://flai-qdrant:6333
QDRANT_API_KEY=your_qdrant_api_key_here
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=20

# RAG relevance thresholds (0..1)
RAG_RELEVANCE_THRESHOLD_DEFAULT=0.3
RAG_RELEVANCE_THRESHOLD_REASONING=0.3

# Enables translation debugging (localization) mode
DEBUG_TRANSLATIONS=False

# Upload folder for media files
UPLOAD_FOLDER=data/uploads
# Documents folder for uploaded documents
DOCUMENTS_FOLDER=data/documents

# Enabling debugging logs
#LOG_LEVEL=DEBUG

# HTTPS/Proxy settings (for nginx reverse proxy)
# Set to true ONLY if behind HTTPS proxy (nginx with Let's Encrypt)
# IMPORTANT: 
#   - Set to TRUE for production with HTTPS (nginx proxy)
#   - Set to FALSE for local HTTP development without proxy
HTTPS_ENABLED=true

# Rate limiting for authentication (prevents brute-force attacks)
# Format: "X per minute;Y per hour"
RATE_LIMIT_ENABLED=true

# Service retry settings
# Number of retry attempts when connecting to external services
SERVICE_RETRY_ATTEMPTS=15
# Delay between retry attempts (seconds)
SERVICE_RETRY_DELAY=2

# Redis queue settings
# TTL for queue results (seconds)
REDIS_RESULT_TTL=3600
# Maximum queue wait time before cancelling (seconds)
QUEUE_MAX_WAIT_TIME=300

# Message pagination settings
# Default number of messages to load
MESSAGES_DEFAULT_LIMIT=100
# Maximum number of messages per request
MESSAGES_MAX_LIMIT=200

# Session and context settings
# Maximum messages to load from history
MAX_HISTORY_MESSAGES=30
# Context safety margin (0.0-1.0, use only X% of calculated capacity)
CONTEXT_SAFETY_MARGIN=0.85
# Template overhead in tokens
TEMPLATE_OVERHEAD_TOKENS=800

# Image token estimation
# Approximate tokens per image
IMAGE_TOKENS_PER_IMAGE=1000

# File validation settings
# Maximum filename extension length
MAX_EXTENSION_LENGTH=10

# Logging settings
# Set to 'json' for structured JSON logging (for ELK, Splunk, etc.)
# Set to 'text' for standard text logging
LOG_FORMAT=text