# BASIC SETTINGS
# ===========================================

# Secret key for Flask sessions (required)
SECRET_KEY=your_secret_key_here

# Time zone (for example: Europe/Moscow, UTC, Europe/London)
TIMEZONE=Europe/Moscow

# Logging level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO

# Image settings
MAX_IMAGE_WIDTH=3840
MAX_IMAGE_HEIGHT=2160
MAX_IMAGE_SIZE_MB=5

# Document upload settings
MAX_DOCUMENT_SIZE_MB=25

# Voice message (recorded) settings
MAX_VOICE_SIZE_MB=5

# Uploaded audio file settings
MAX_AUDIO_SIZE_MB=5

# Ollama settings (required)
#OLLAMA_URL=http://flai-ollama:11434

# Automatic1111 settings (for image generation)
AUTOMATIC1111_URL=http://flai-sd:7860
# Model for Automatic1111 (Stable Diffusion checkpoint)
AUTOMATIC1111_MODEL=RealVisXL_V4.0.safetensors
# Timeout for image generation
AUTOMATIC1111_TIMEOUT=180

# URL for Whisper API (audio transcription)
WHISPER_API_URL=http://flai-whisper:9000/asr

# Audio transcription timeout
WHISPER_API_TIMEOUT=120

# Video surveillance system settings
CAMERA_API_URL=http://host.docker.internal:5005
CAMERA_ENABLED=true                # true - the module is enabled, false - disabled
# Timeout for taking pictures from cameras
CAMERA_API_TIMEOUT=15
# Camera availability check interval (seconds)
CAMERA_CHECK_INTERVAL=30

# Piper TTS settings (text-to-speech)
PIPER_URL=http://flai-piper:8888/tts
PIPER_TIMEOUT=30

# Token estimation: approximate number of characters per token
TOKEN_CHARS=3
# Percentage of model's context window reserved for conversation history (e.g., 75)
CONTEXT_HISTORY_PERCENT=75

# Qdrant settings for RAG (optional)
QDRANT_URL=http://flai-qdrant:6333
QDRANT_API_KEY=your_qdrant_api_key_here
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=10

# Enables translation debugging (localization) mode
DEBUG_TRANSLATIONS=False

# Upload folder for media files
UPLOAD_FOLDER=data/uploads
# Documents folder for uploaded documents
DOCUMENTS_FOLDER=data/documents

# Enabling debugging logs
#LOG_LEVEL=DEBUG