# BASIC SETTINGS (ALL VARIABLES ARE REQUIRED)
# ===========================================

# Secret key for Flask sessions

# Time zone (for example: Europe/Moscow, UTC, Europe/London)
TIMEZONE=Europe/Moscow

# Image settings
MAX_IMAGE_WIDTH=3840
MAX_IMAGE_HEIGHT=2160
MAX_IMAGE_SIZE_MB=5

# Document upload settings
MAX_DOCUMENT_SIZE_MB=25

# Voice message (recorded) settings
MAX_VOICE_SIZE_MB=5

# Uploaded audio file settings
MAX_AUDIO_SIZE_MB=5

# Ollama settings
OLLAMA_URL=http://host.docker.internal:11434

# Router model (chat model)
LLM_CHAT_MODEL=qwen3:4b-instruct-2507-q4_K_M
LLM_CHAT_MODEL_CONTEXT_WINDOW=8192
LLM_CHAT_TEMPERATURE=0.1
LLM_CHAT_TOP_P=0.1
LLM_CHAT_TIMEOUT=60

# A multimodal model (for images)
LLM_MULTIMODAL_MODEL=qwen3-vl:8b-instruct-q4_K_M
LLM_MULTIMODAL_MODEL_CONTEXT_WINDOW=16384
LLM_MULTIMODAL_TEMPERATURE=0.7
LLM_MULTIMODAL_TOP_P=0.9
LLM_MULTIMODAL_TIMEOUT=120

# The reasoning model (for complex queries)
LLM_REASONING_MODEL=gpt-oss:20b
LLM_REASONING_MODEL_CONTEXT_WINDOW=32768
LLM_REASONING_TEMPERATURE=0.7
LLM_REASONING_TOP_P=0.9
LLM_REASONING_TIMEOUT=300

# Automatic1111 settings (for image generation)
AUTOMATIC1111_URL=http://host.docker.internal:7860
# Model for Automatic1111 (Stable Diffusion checkpoint)
AUTOMATIC1111_MODEL=cyberrealisticXL_v90.safetensors
# Timeout for image generation
AUTOMATIC1111_TIMEOUT=180

# URL for Whisper API (audio transcription)
WHISPER_API_URL=http://host.docker.internal:9000/asr
# Audio transcription timeout
WHISPER_API_TIMEOUT=120

# Video surveillance system settings
CAMERA_API_URL=http://host.docker.internal:5005
CAMERA_ENABLED=true                # true - the module is enabled, false - disabled
# Timeout for taking pictures from cameras
CAMERA_API_TIMEOUT=15
# Camera availability check interval (seconds)
CAMERA_CHECK_INTERVAL=30

# Piper TTS settings (text-to-speech)
PIPER_URL=http://host.docker.internal:18888/tts
PIPER_TIMEOUT=30

# Token estimation: approximate number of characters per token
TOKEN_CHARS=3
# Percentage of model's context window reserved for conversation history (e.g., 75)
CONTEXT_HISTORY_PERCENT=75

# Qdrant settings for RAG
QDRANT_URL=http://host.docker.internal:6333
QDRANT_API_KEY="your_qdrant_api_key_here"
EMBEDDING_MODEL=bge-m3:latest
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=10

# Enables translation debugging (localization) mode
DEBUG_TRANSLATIONS=False

# Upload folder for media files
UPLOAD_FOLDER=data/uploads
# Documents folder for uploaded documents
DOCUMENTS_FOLDER=data/documents