# BASIC SETTINGS
# ===========================================

# Secret key for Flask sessions (required)
SECRET_KEY=your_secret_key_here

# Time zone (for example: Europe/Moscow, UTC, Europe/London)
TIMEZONE=Europe/Moscow

# Image settings
MAX_IMAGE_WIDTH=3840
MAX_IMAGE_HEIGHT=2160
MAX_IMAGE_SIZE_MB=5

# Document upload settings
MAX_DOCUMENT_SIZE_MB=5

# Maximum request body size in MB (applies to all uploads)
MAX_CONTENT_LENGTH_MB=50

# Voice message (recorded) settings
MAX_VOICE_SIZE_MB=5

# Uploaded audio file settings
MAX_AUDIO_SIZE_MB=5

# ===========================================
# LLM backend (required)
# ===========================================
# Backend type: 'llama-swap' (default, recommended) or 'llamacpp' (direct)
LLAMACP_BACKEND=llama-swap
# URL to llama-swap (proxy, dynamically manages llama-server instances)
LLAMA_SWAP_URL=http://flai-llamaswap:8080
# URL to llama-server (only used when LLAMACP_BACKEND=llamacpp)
# LLAMACPP_URL=http://flai-llamacpp:8033

# ===========================================
# stable-diffusion.cpp (optional - image generation)
# ===========================================
# Generation model: Z-Image Turbo (only supported model)
SD_MODEL_TYPE=z_image_turbo
# Editing model: Flux.2 Klein 4B (always used for image editing)
SD_EDIT_MODEL_TYPE=flux-2-klein-4b
# URL to sd-wrapper (HTTP API around sd-cli, port 7861)
SD_WRAPPER_URL=http://flai-sd:7861
# Timeout for image generation and editing (seconds)
SD_CPP_TIMEOUT=900
# Default generation parameters (applied when model doesn't specify)
SD_CPP_DEFAULT_WIDTH=1024
SD_CPP_DEFAULT_HEIGHT=1024
SD_CPP_DEFAULT_CFG_SCALE=1.0
SD_CPP_DEFAULT_STEPS=10

# ===========================================
# LTX-Video (optional - video generation)
# ===========================================
# URL to ltx-wrapper (HTTP API around LTX-Video, port 7872)
LTX_VIDEO_WRAPPER_URL=http://flai-ltxvideo:7872
# Model to use for video generation
LTX_VIDEO_MODEL=ltxv-2b-0.9.8-distilled
# Timeout for video generation (seconds)
LTX_VIDEO_TIMEOUT=600

# ===========================================
# Storage quotas (per user, in MB)
# ===========================================
MAX_UPLOAD_STORAGE_MB=500
MAX_DOCUMENTS_STORAGE_MB=50
MAX_DOCUMENTS_PER_USER=50

# ===========================================
# Whisper ASR (optional - speech recognition)
# ===========================================
# URL for Whisper API (audio transcription)
WHISPER_API_URL=http://flai-whisper:9000/asr
# Timeout for speech recognition (seconds)
WHISPER_API_TIMEOUT=120

# ===========================================
# Camera (optional)
# ===========================================
CAMERA_API_URL=http://flai-room-snapshot-api:5000
CAMERA_ENABLED=true
CAMERA_API_TIMEOUT=15
CAMERA_CHECK_INTERVAL=30

# ===========================================
# Piper TTS (optional - text-to-speech)
# ===========================================
PIPER_URL=http://flai-piper:8888/tts
PIPER_TIMEOUT=30

# ===========================================
# SearXNG (optional - web search)
# ===========================================
# URL to SearXNG instance (requires --profile with-search)
# SEARXNG_URL=http://flai-searxng:8080
# SEARXNG_TIMEOUT=10
# SEARXNG_MAX_RESULTS=7
# SEARXNG_MAX_RESULTS_CHARS=7000
# RAG_MAX_RESULTS_CHARS=5000

# ===========================================
# Context settings
# ===========================================
TOKEN_CHARS=3
CONTEXT_HISTORY_PERCENT=75
CONTEXT_SAFETY_MARGIN=0.85
TEMPLATE_OVERHEAD_TOKENS=800
MAX_HISTORY_MESSAGES=30
IMAGE_TOKENS_PER_IMAGE=1000

# ===========================================
# Qdrant (optional - RAG)
# ===========================================
QDRANT_URL=http://flai-qdrant:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# SuperLocalMemory (long-term memory)
# Uncomment to enable long-term memory with SLM (requires --profile with-slm)
# SLM_URL=http://flai-slm:8766
# SLM_RECALL_LIMIT=7

# ===========================================
# SLM Merge (background fact cleanup)
# ===========================================
# Max facts to fetch from SLM for merge
MERGE_MAX_FACTS=100
# Context size for CPU merge model (tokens)
MERGE_CONTEXT_SIZE=4096
# Max characters per fact in merge prompt
MERGE_FACT_MAX_CHARS=120
# Max facts that fit in MERGE_CONTEXT_SIZE (auto-calculated, override if needed)
MERGE_MAX_FIT_FACTS=62

# ===========================================
# SLM rule-based extraction and merge
# ===========================================
# Semantic similarity threshold for deduplication (0.0-1.0)
SLM_SIMILARITY_THRESHOLD=0.85
# Auto-archive facts older than N days with low confidence
SLM_TEMPORAL_DECAY_DAYS=90
# Minimum confidence score to survive temporal decay
SLM_MIN_CONFIDENCE_FOR_DECAY=0.5
# RAG settings now stored in DB (admin panel) - defaults are used if not set
# RAG_CHUNK_SIZE (default: 500)
# RAG_CHUNK_OVERLAP (default: 50)
# RAG_CHUNK_STRATEGY (default: fixed)
# RAG_TOP_K (default: 80)
# RAG_CONTEXT_PERCENT (default: 30)
# RAG_RELEVANCE_THRESHOLD_DEFAULT (default: 0.3)

# ===========================================
# Upload paths
# ===========================================
UPLOAD_FOLDER=data/uploads
DOCUMENTS_FOLDER=data/documents

# ===========================================
# Security
# ===========================================
HTTPS_ENABLED=false
MAX_EXTENSION_LENGTH=10

# ===========================================
# Retry settings
# ===========================================
SERVICE_RETRY_ATTEMPTS=5
SERVICE_RETRY_DELAY=2

# ===========================================
# Redis queue
# ===========================================
REDIS_RESULT_TTL=3600
QUEUE_MAX_WAIT_TIME=300

# ===========================================
# Pagination
# ===========================================
MESSAGES_DEFAULT_LIMIT=100
MESSAGES_MAX_LIMIT=200

# ===========================================
# Debug settings
# ===========================================
DEBUG_API_ENABLED=false
DEBUG_JS=true
DEBUG_TRANSLATIONS=false
DEBUG_TOKEN_ESTIMATION=false

# ===========================================
# PostgreSQL (required)
# ===========================================
# IMPORTANT: Change the password below in production!
DATABASE_URL=postgresql://flai:flai_password@flai-postgres:5432/flai

