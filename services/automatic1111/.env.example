# services/automatic1111/.env.example
# Automatic1111 standalone deployment configuration

# Port for Automatic1111 web UI and API
SD_PORT=7860

# Optional: Basic authentication (uncomment to enable)
# SD_USERNAME=your_username
# SD_PASSWORD=your_password

# Optional: Host binding (default: 0.0.0.0)
# SD_HOST=0.0.0.0