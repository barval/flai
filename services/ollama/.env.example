# services/ollama/.env.example
# Ollama standalone deployment configuration

# Port for Ollama API
OLLAMA_PORT=11434

# Request timeout
OLLAMA_REQUEST_TIMEOUT=1200s

# Maximum number of models to keep loaded
OLLAMA_MAX_LOADED_MODELS=1

# Keep alive time for models (0 = unload immediately)
OLLAMA_KEEP_ALIVE=0